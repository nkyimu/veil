# Veil Guardian — Environment Configuration
# Copy to .env and fill in your values

# Base Sepolia RPC
BASE_RPC_URL=https://sepolia.base.org

# Contract addresses (deployed to Base Sepolia)
VEIL_VAULT_CONTRACT=0x2f881af96415a452807baf6a23b73129d57f8d7a
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Venice AI — Private Cognition (no data retention)
# Get API key: https://venice.ai (Pro account or API access)
VENICE_API_URL=https://api.venice.ai/api/v1
VENICE_API_KEY=your-venice-api-key
VENICE_MODEL=llama-3.3-70b

# Self Protocol (ZK proofs — optional for MVP)
SELF_PROTOCOL_APP_ID=

# Locus API (agent-native USDC payments — x402+Locus protocol)
# Docs: docs.paywithlocus.com | Hackathon prize: $3,000
# Guardian pre-registered (2026-03-15). Retrieve from macOS Keychain:
#   security find-generic-password -a "veil-guardian" -s "locus-api-key" -w
LOCUS_API_URL=https://beta-api.paywithlocus.com/api
LOCUS_API_KEY=
LOCUS_OWNER_ADDRESS=0x2A32a443e07C7C72191FcC5c293324B2eFC02bc6
LOCUS_WALLET_ADDRESS=0x680ab339ea34d34a939080dfb3aef932b3892b4a
LOCUS_QUERY_PRICE_USDC=0.01
# Set to false to disable Locus and fall back to x402-only mode
USE_LOCUS=true

# Frontend
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_VEIL_VAULT_CONTRACT=0x2f881af96415a452807baf6a23b73129d57f8d7a
NEXT_PUBLIC_CHAIN_ID=84532

# Guardian server
GUARDIAN_PORT=3001
GUARDIAN_ADDRESS=
GUARDIAN_LOG_LEVEL=debug
