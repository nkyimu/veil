# Contracts (set after deployment)
VEIL_VAULT_CONTRACT=0x...
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Self Protocol
SELF_PROTOCOL_APP_ID=your_app_id
